{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["findings"],
  "additionalProperties": false,
  "properties": {
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["category", "severity", "title", "snippet", "explanation", "fix", "rewrite"],
        "additionalProperties": false,
        "properties": {
          "category": { "type": "string" },
          "severity": { "type": "string", "enum": ["critical", "major", "minor"] },
          "title": { "type": "string" },
          "snippet": { "type": "string" },
          "explanation": { "type": "string" },
          "fix": { "type": "string" },
          "rewrite": { "type": ["string", "null"] }
        }
      }
    }
  }
}
